<Window x:Class="RunMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Run Monitor"
        Width="760"
        Height="470"
        MinWidth="760"
        MinHeight="470"
        Background="#0C1116"
        Foreground="#E7EDF4"
        FontFamily="Bahnschrift"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#0C1116" />
        <SolidColorBrush x:Key="CardBrush" Color="#131A21" />
        <SolidColorBrush x:Key="CardAltBrush" Color="#0F151B" />
        <SolidColorBrush x:Key="HeroBrush" Color="#101820" />
        <SolidColorBrush x:Key="BorderBrushDark" Color="#24313D" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E7EDF4" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#95A7B8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#58D68D" />
        <SolidColorBrush x:Key="AccentMutedBrush" Color="#183527" />
        <SolidColorBrush x:Key="ButtonBrush" Color="#1A232C" />
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#22303B" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource ButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2A3A47" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18"
                Background="{StaticResource HeroBrush}"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Training Run Monitor"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Live status pulled from the training log" />
                    <TextBlock Style="{StaticResource SectionLabelStyle}"
                               Margin="0,18,0,0"
                               Text="ACTIVE RUN" />
                    <TextBlock x:Name="RunNameText"
                               Margin="0,4,0,0"
                               FontSize="20"
                               FontFamily="Segoe UI"
                               FontWeight="SemiBold"
                               Text="Waiting for log..." />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="24,0,0,0"
                            HorizontalAlignment="Right">
                    <Border x:Name="StageBadgeBorder"
                            Padding="14,8"
                            HorizontalAlignment="Right"
                            Background="#182634"
                            BorderBrush="#314458"
                            BorderThickness="1"
                            CornerRadius="999">
                        <TextBlock x:Name="StageText"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Text="Idle" />
                    </Border>
                    <Border Margin="0,14,0,0"
                            Padding="14,12"
                            Background="{StaticResource CardAltBrush}"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="ETA" />
                            <TextBlock x:Name="EtaText"
                                       Margin="0,5,0,0"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="Calculating..." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Padding="16"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="16">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ProgressText"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="No progress yet" />
                    <TextBlock x:Name="PercentText"
                               Grid.Column="1"
                               Margin="12,0,0,0"
                               FontSize="15"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Overall 0.0%" />
                </Grid>

                <Border Margin="0,12,0,0"
                        Height="18"
                        Background="#192028"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="999">
                    <ProgressBar x:Name="RunProgressBar"
                                 Margin="2"
                                 Minimum="0"
                                 Maximum="100"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="{StaticResource AccentMutedBrush}"
                                 BorderThickness="0" />
                </Border>

                <TextBlock Margin="0,14,0,0"
                           Style="{StaticResource CardTitleStyle}"
                           Text="PHASE PROGRESSION" />

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="PhaseWarmupBorder"
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            Padding="0,8"
                            Background="#10161D"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock x:Name="PhaseWarmupText"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Warmup" />
                    </Border>

                    <Border x:Name="PhaseInitialValBorder"
                            Grid.Column="1"
                            Margin="0,0,8,0"
                            Padding="0,8"
                            Background="#10161D"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock x:Name="PhaseInitialValText"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Init Val" />
                    </Border>

                    <Border x:Name="PhaseTrainingBorder"
                            Grid.Column="2"
                            Margin="0,0,8,0"
                            Padding="0,8"
                            Background="#10161D"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock x:Name="PhaseTrainingText"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Training" />
                    </Border>

                    <Border x:Name="PhaseFinalValBorder"
                            Grid.Column="3"
                            Margin="0,0,8,0"
                            Padding="0,8"
                            Background="#10161D"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock x:Name="PhaseFinalValText"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Final Val" />
                    </Border>

                    <Border x:Name="PhasePackagingBorder"
                            Grid.Column="4"
                            Margin="0,0,8,0"
                            Padding="0,8"
                            Background="#10161D"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock x:Name="PhasePackagingText"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Package" />
                    </Border>

                    <Border x:Name="PhaseQuantValBorder"
                            Grid.Column="5"
                            Margin="0,0,8,0"
                            Padding="0,8"
                            Background="#10161D"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock x:Name="PhaseQuantValText"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Quant Val" />
                    </Border>

                    <Border x:Name="PhaseDoneBorder"
                            Grid.Column="6"
                            Padding="0,8"
                            Background="#10161D"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock x:Name="PhaseDoneText"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Done" />
                    </Border>
                </Grid>

                <TextBlock x:Name="UpdatedText"
                           Margin="0,10,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Polling every 2s" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="0.85*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,10,0"
                    Padding="16"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="16">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitleStyle}" Text="SNAPSHOT" />
                    <TextBlock x:Name="MetricsText"
                               Margin="0,10,0,0"
                               FontSize="16"
                               FontFamily="Segoe UI"
                               TextWrapping="Wrap"
                               Text="No metrics yet" />
                    <TextBlock x:Name="TimingText"
                               Margin="0,10,0,0"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Text="No timing yet" />

                    <TextBlock Style="{StaticResource CardTitleStyle}"
                               Margin="0,18,0,0"
                               Text="ACTIVE LOG" />
                    <TextBlock x:Name="FileText"
                               Margin="0,10,0,0"
                               FontSize="13"
                               FontFamily="Consolas"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Text="No log selected" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="16"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource CardTitleStyle}" Text="LATEST PARSED EVENT" />
                    <Border Grid.Row="1"
                            Margin="0,12,0,0"
                            Padding="12"
                            Background="{StaticResource CardAltBrush}"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TextBlock x:Name="LastLineText"
                                       FontSize="13"
                                       FontFamily="Consolas"
                                       LineHeight="20"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Text="No parsed events yet" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,16,0,0" LastChildFill="False">
            <TextBlock VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Text="Monitor is read-only and safe to leave open during training." />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Margin="8,0,0,0" Click="LatestButton_Click">Latest</Button>
                <Button Margin="8,0,0,0" Click="BrowseButton_Click">Browse</Button>
                <Button Margin="8,0,0,0" Click="OpenButton_Click">Open Log</Button>
                <Button Margin="8,0,0,0" Click="RefreshButton_Click">Refresh</Button>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
